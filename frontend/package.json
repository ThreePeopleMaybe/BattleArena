{
  "name": "battlearena",
  "version": "1.0.0",
  "main": "index.ts",
"scripts": {
  "start": "dotenv -e .env.local -- expo start",
  "start:local": "dotenv -e .env.local -- expo start",
  "start:qa": "dotenv -e .env.qa -- expo start",
  "start:prod": "dotenv -e .env.production -- expo start",
  "android": "dotenv -e .env.local -- expo start --android",
  "android:qa": "dotenv -e .env.qa -- expo start --android",
  "ios": "dotenv -e .env.local -- expo start --ios",
  "ios:qa": "dotenv -e .env.qa -- expo start --ios",
  "web": "dotenv -e .env.local -- expo start --web --offline",
  "web:qa": "dotenv -e .env.qa -- expo start --web"
},
  "dependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@react-native-async-storage/async-storage": "3.0.1",
    "@react-navigation/native": "7.1.29",
    "@react-navigation/native-stack": "7.14.0",
    "@tanstack/react-query": "5.94.5",
    "expo": "~54.0.33",
    "axios": "1.13.6",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "dotenv-cli": "^11.0.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}